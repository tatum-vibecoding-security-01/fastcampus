# Claude API 키를 발급받아 아래에 넣고, 이 파일을 .env.local 로 복사하세요.
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — URL은 대시보드 Connect 다이얼로그, 키는 Settings → API Keys 에서 복사
# publishable 키만 사용하고, 접근 통제는 RLS 정책으로 함. (secret 키는 쓰지 않음)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# ── Supabase 인증(로그인) 설정 체크리스트 ─────────────────────────────
# 1) Authentication → URL Configuration → Redirect URLs 에 아래 추가:
#      http://localhost:3000/auth/callback   (개발)
#      https://<배포도메인>/auth/callback     (운영)
# 2) 이메일/비밀번호: Authentication → Providers → Email 활성화
#    (초기 개발 시 "Confirm email" 을 꺼두면 가입 즉시 로그인됩니다.)
# 3) Google: Providers → Google 에 Google Cloud OAuth 클라이언트의
#    Client ID / Secret 입력. Google 콘솔의 승인된 리디렉션 URI 에는
#      https://<프로젝트>.supabase.co/auth/v1/callback 를 등록.
# 4) Kakao: Providers → Kakao 에 카카오 REST API 키/Client Secret 입력.
#    카카오 개발자 콘솔 Redirect URI 에도 위 supabase .../auth/v1/callback 등록.
